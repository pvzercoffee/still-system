<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizVendorQrcodeMapper">

    <resultMap type="BizVendorQrcode" id="BizVendorQrcodeResult">
        <result property="shortId" column="short_id" />
        <result property="targetType" column="target_type" />
        <result property="vendorId" column="vendor_id" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectBizVendorQrcodeVo">
        select short_id, target_type, vendor_id, status, create_time, update_time
        from biz_vendor_qrcode
    </sql>

    <select id="selectByShortId" parameterType="String" resultMap="BizVendorQrcodeResult">
        <include refid="selectBizVendorQrcodeVo"/>
        where short_id = #{shortId}
    </select>

    <select id="selectByVendorIdAndTargetType" resultMap="BizVendorQrcodeResult">
        <include refid="selectBizVendorQrcodeVo"/>
        where vendor_id = #{vendorId}
          and target_type = #{targetType}
        limit 1
    </select>

    <insert id="insertBizVendorQrcode" parameterType="BizVendorQrcode">
        insert into biz_vendor_qrcode (
            short_id,
            target_type,
            vendor_id,
            status,
            create_time,
            update_time
        ) values (
            #{shortId},
            #{targetType},
            #{vendorId},
            #{status},
            #{createTime},
            #{updateTime}
        )
    </insert>
</mapper>

