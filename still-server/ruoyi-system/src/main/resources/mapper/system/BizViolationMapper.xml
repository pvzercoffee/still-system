<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizViolationMapper">
    
    <resultMap type="BizViolation" id="BizViolationResult">
        <result property="violationId"    column="violation_id"    />
        <result property="vendorId"    column="vendor_id"    />
        <result property="inspectorId"    column="inspector_id"    />
        <result property="violationType"    column="violation_type"    />
        <result property="photoUrl"    column="photo_url"    />
        <result property="deductScore"    column="deduct_score"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectBizViolationVo">
        select violation_id, vendor_id, inspector_id, violation_type, photo_url, deduct_score, status, create_by, create_time, update_by, update_time, remark from biz_violation
    </sql>

    <select id="selectBizViolationList" parameterType="BizViolation" resultMap="BizViolationResult">
        <include refid="selectBizViolationVo"/>
        <where>  
            <if test="vendorId != null "> and vendor_id = #{vendorId}</if>
            <if test="inspectorId != null "> and inspector_id = #{inspectorId}</if>
            <if test="violationType != null  and violationType != ''"> and violation_type = #{violationType}</if>
            <if test="photoUrl != null  and photoUrl != ''"> and photo_url = #{photoUrl}</if>
            <if test="deductScore != null "> and deduct_score = #{deductScore}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectBizViolationByViolationId" parameterType="Long" resultMap="BizViolationResult">
        <include refid="selectBizViolationVo"/>
        where violation_id = #{violationId}
    </select>

    <insert id="insertBizViolation" parameterType="BizViolation" useGeneratedKeys="true" keyProperty="violationId">
        insert into biz_violation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="vendorId != null">vendor_id,</if>
            <if test="inspectorId != null">inspector_id,</if>
            <if test="violationType != null and violationType != ''">violation_type,</if>
            <if test="photoUrl != null">photo_url,</if>
            <if test="deductScore != null">deduct_score,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="vendorId != null">#{vendorId},</if>
            <if test="inspectorId != null">#{inspectorId},</if>
            <if test="violationType != null and violationType != ''">#{violationType},</if>
            <if test="photoUrl != null">#{photoUrl},</if>
            <if test="deductScore != null">#{deductScore},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateBizViolation" parameterType="BizViolation">
        update biz_violation
        <trim prefix="SET" suffixOverrides=",">
            <if test="vendorId != null">vendor_id = #{vendorId},</if>
            <if test="inspectorId != null">inspector_id = #{inspectorId},</if>
            <if test="violationType != null and violationType != ''">violation_type = #{violationType},</if>
            <if test="photoUrl != null">photo_url = #{photoUrl},</if>
            <if test="deductScore != null">deduct_score = #{deductScore},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where violation_id = #{violationId}
    </update>

    <delete id="deleteBizViolationByViolationId" parameterType="Long">
        delete from biz_violation where violation_id = #{violationId}
    </delete>

    <delete id="deleteBizViolationByViolationIds" parameterType="String">
        delete from biz_violation where violation_id in 
        <foreach item="violationId" collection="array" open="(" separator="," close=")">
            #{violationId}
        </foreach>
    </delete>
</mapper>