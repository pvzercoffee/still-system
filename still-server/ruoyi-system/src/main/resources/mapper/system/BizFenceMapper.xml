<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizFenceMapper">
    
    <resultMap type="BizFence" id="BizFenceResult">
        <result property="fenceId"    column="fence_id"    />
        <result property="fenceName"    column="fence_name"    />
        <result property="polygonPoints"    column="polygon_points"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectBizFenceVo">
        select fence_id, fence_name, polygon_points, status, create_by, create_time, update_by, update_time, remark from biz_fence
    </sql>

    <select id="selectBizFenceList" parameterType="BizFence" resultMap="BizFenceResult">
        <include refid="selectBizFenceVo"/>
        <where>  
            <if test="fenceName != null  and fenceName != ''"> and fence_name like concat('%', #{fenceName}, '%')</if>
            <if test="polygonPoints != null  and polygonPoints != ''"> and polygon_points = #{polygonPoints}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectBizFenceByFenceId" parameterType="Long" resultMap="BizFenceResult">
        <include refid="selectBizFenceVo"/>
        where fence_id = #{fenceId}
    </select>

    <insert id="insertBizFence" parameterType="BizFence" useGeneratedKeys="true" keyProperty="fenceId">
        insert into biz_fence
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="fenceName != null and fenceName != ''">fence_name,</if>
            <if test="polygonPoints != null and polygonPoints != ''">polygon_points,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="fenceName != null and fenceName != ''">#{fenceName},</if>
            <if test="polygonPoints != null and polygonPoints != ''">#{polygonPoints},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateBizFence" parameterType="BizFence">
        update biz_fence
        <trim prefix="SET" suffixOverrides=",">
            <if test="fenceName != null and fenceName != ''">fence_name = #{fenceName},</if>
            <if test="polygonPoints != null and polygonPoints != ''">polygon_points = #{polygonPoints},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where fence_id = #{fenceId}
    </update>

    <delete id="deleteBizFenceByFenceId" parameterType="Long">
        delete from biz_fence where fence_id = #{fenceId}
    </delete>

    <delete id="deleteBizFenceByFenceIds" parameterType="String">
        delete from biz_fence where fence_id in 
        <foreach item="fenceId" collection="array" open="(" separator="," close=")">
            #{fenceId}
        </foreach>
    </delete>
</mapper>