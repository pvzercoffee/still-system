# ==========================================
# 操作系统 & 临时文件 (WSL / Windows / macOS)
# ==========================================
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp
*~
# WSL/Linux 产生的临时文件
/tmp/

# ==========================================
# IntelliJ IDEA & VS Code (极致干净)
# ==========================================
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.classpath
.project
.factorypath
bin/
out/

# ==========================================
# 后端 - Spring Boot (Java/Maven)
# ==========================================
# 排除编译产物
**/target/
# 排除日志文件 (记得你之前遇到的权限问题，这里直接屏蔽)
**/logs/
*.log
# 排除本地配置文件 (如果你有自定义的 local 配置)
**/src/main/resources/application-local.yml

# ==========================================
# 前端 - Vue 3 (Vite/Node/NPM)
# ==========================================
# 排除依赖包 (这个最重要)
**/node_modules/
# 排除打包产物
**/dist/
# 排除打包产生的统计文件
**/stats.html
# 排除环境变量本地覆盖文件
.env.local
.env.*.local
# 排除 npm 错误日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 其他工具
# ==========================================
# 如果你用了 Docker
.docker/
# 如果你用了 FRP 做内网穿透
**/frp/*.ini
